{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "UserCleanupSettings": {
    "Enabled": true,
    "RetentionDays": 30,
    "RunEveryHours": 24,
    "BatchSize": 100
