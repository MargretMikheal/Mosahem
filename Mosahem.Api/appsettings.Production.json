{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MainConnection": "Server=${DB_HOST};Database=${DB_NAME};User Id=${DB_USER};Password=${DB_PASSWORD};TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "MOSAHM_SUPER_SECRET_KEY_CHANGE_ME_32_CHARS",
    "Issuer": "mosahem.Api",
    "Audience": "mosahem.Client",
    "DurationInMinutes": 60
  },
  "Authentication": {
    "Google": {
      "ClientId": "${GOOGLE_CLIENT_ID}",
      "ClientSecret": "${GOOGLE_CLIENT_SECRET}"
    }
  },
  "MailSettings": {
    "Email": "${MAIL_EMAIL}",
    "DisplayName": "Mosahem",
    "Password": "${MAIL_PASSWORD}",
    "Host": "${MAIL_HOST}",
    "Port": 587,
    "EnableSsl": true
  },
  "FileStorageSettings": {
    "BucketName": "${FILE_BUCKET_NAME}",
    "ServiceUrl": "${FILE_SERVICE_URL}",
    "PublicUrl": "${FILE_PUBLIC_URL}",
    "AccessKey": "${FILE_ACCESS_KEY}",
    "SecretKey": "${FILE_SECRET_KEY}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning"
    }
  },
  "UserCleanupSettings": {
    "Enabled": true,
    "RetentionDays": 30,
    "RunEveryHours": 24,
    "BatchSize": 100
  },
  "TempFilesCleanupSettings": {
    "Enabled": true,
    "RunEveryHours": 24
  }
}
